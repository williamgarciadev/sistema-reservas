# Production Environment Variables Template
# Copy this file to .env.production and fill in your values

# ===========================================
# DOMAINS
# ===========================================
FRONTEND_DOMAIN=reservas.dominio.com
API_DOMAIN=api.reservas.dominio.com
TRAEFIK_DOMAIN=traefik.reservas.dominio.com
FRONTEND_URL=https://reservas.dominio.com

# ===========================================
# DATABASE - PostgreSQL
# ===========================================
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
DB_NAME=sistema_reservas

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# JWT SECRETS - Generate secure random strings
# Use: openssl rand -base64 32
# ===========================================
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# API CONFIGURATION
# ===========================================
NEXT_PUBLIC_API_URL=https://api.reservas.dominio.com/api
PORT=3001

# ===========================================
# EMAIL - Resend
# ===========================================
RESEND_API_KEY=re_CHANGE_ME_API_KEY

# ===========================================
# PAYMENTS - Stripe
# ===========================================
STRIPE_SECRET_KEY=sk_live_CHANGE_ME_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME_WEBHOOK_SECRET

# ===========================================
# TRAEFIK - Let's Encrypt
# ===========================================
ACME_EMAIL=admin@dominio.com

# ===========================================
# DASHBOARD AUTH - Generate with htpasswd
# Command: htpasswd -nb admin password
# ===========================================
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$H6uskkkW$$IgXLP6ewTrSuBkTrqE8wj/

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
NODE_ENV=production
